<%= form_with(model: import_row, class: "contents") do |form| %>
  <% if import_row.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(import_row.errors.count, "error") %> prohibited this import_row from being saved:</h2>

      <ul class="list-disc ml-6">
        <% import_row.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :building_name %>
    <%= form.text_field :building_name, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": import_row.errors[:building_name].none?, "border-red-400 focus:outline-red-600": import_row.errors[:building_name].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :street_address %>
    <%= form.text_field :street_address, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": import_row.errors[:street_address].none?, "border-red-400 focus:outline-red-600": import_row.errors[:street_address].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :unit %>
    <%= form.text_field :unit, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": import_row.errors[:unit].none?, "border-red-400 focus:outline-red-600": import_row.errors[:unit].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :city %>
    <%= form.text_field :city, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": import_row.errors[:city].none?, "border-red-400 focus:outline-red-600": import_row.errors[:city].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :state %>
    <%= form.text_field :state, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": import_row.errors[:state].none?, "border-red-400 focus:outline-red-600": import_row.errors[:state].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :zip_code %>
    <%= form.text_field :zip_code, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": import_row.errors[:zip].none?, "border-red-400 focus:outline-red-600": import_row.errors[:zip].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :import_id %>
    <%= form.text_field :import_id, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": import_row.errors[:import_id].none?, "border-red-400 focus:outline-red-600": import_row.errors[:import_id].any?}] %>
  </div>

  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
